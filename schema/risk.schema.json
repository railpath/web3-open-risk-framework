{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web3 Risk Entry",
  "type": "object",
  "required": ["id", "title", "category", "scope", "owner", "severity", "probability", "impact", "objectives"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^R:[A-Z0-9_.]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "FINANCIAL",
        "DEPENDENCY",
        "TECHNICAL",
        "APPLICATION",
        "ORGANIZATIONAL",
        "CONTRACT",
        "HUMAN_ERROR",
        "COMPLIANCE"
      ],
      "description": "Risk category - see framework/docs/categories.md for definitions"
    },
    "type": {
      "type": "string",
      "enum": ["QUALITATIVE", "QUANTITATIVE", "HYBRID"]
    },
    "scope": {
      "type": "string",
      "enum": [
        "APPLICATION",
        "ASSET",
        "NETWORK",
        "TRADE",
        "CUSTODY",
        "GOVERNANCE"
      ],
      "description": "Primary scope of action for this risk (see framework/docs/scopes.md)"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "APPLICATION",
          "ASSET",
          "NETWORK",
          "TRADE",
          "CUSTODY",
          "GOVERNANCE"
        ]
      },
      "description": "Multiple scopes if risk applies to several action contexts"
    },
    "owner": {
      "type": "string",
      "description": "Primary risk owner"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "CRITICAL",
        "HIGH",
        "MEDIUM",
        "LOW"
      ],
      "description": "Overall risk severity"
    },
    "probability": {
      "type": "string",
      "enum": [
        "VERY_HIGH",
        "HIGH",
        "MEDIUM",
        "LOW",
        "VERY_LOW"
      ],
      "description": "Likelihood of risk occurrence"
    },
    "impact": {
      "type": "string",
      "enum": [
        "CATASTROPHIC",
        "SEVERE",
        "MODERATE",
        "MINOR",
        "NEGLIGIBLE"
      ],
      "description": "Potential impact if risk materializes"
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          }
        },
        "required": ["type", "direction", "goal"]
      }
    },
    "measures": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^M:[A-Z_]+(?:\\.FIDLEG)?$"
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string"
    },
    "scopeJustification": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "rationaleForAction": {
      "type": "string"
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["fidleg", "euMiFID", "usSec", "ukFCA", "sgMAS"]
      },
      "description": "List of active regulatory extensions for this risk",
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
