{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Web3 Indicator Entry",
  "type": "object",
  "required": ["id", "title", "version", "lastUpdate"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^I:[A-Z_]+(\\.[A-Z]+)?$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string"
    },
    "lastUpdate": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Calendar date (YYYY-MM-DD), no time component"
    },
    "description": {
      "type": "string",
      "description": "Short description of the indicator (used in YAML, not duplicates in Markdown)"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Conditions that must be met for this indicator to be calculated"
    },
    "methodology": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Structured methodology steps"
    },
    "computation": {
      "type": "object",
      "description": "Structured computation details for programmatic processing",
      "properties": {
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              },
              "formula": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              },
              "weight": {
                "type": "number"
              }
            }
          }
        },
        "dataSources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["oracle", "api", "onChain", "offChain", "indexer", "custom"]
              },
              "provider": {
                "type": "string"
              },
              "endpoint": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "frequency": {
          "type": "string",
          "enum": ["realTime", "hourly", "daily", "weekly", "monthly", "onDemand"]
        }
      }
    },
    "thresholds": {
      "type": "object",
      "description": "Risk thresholds for the indicator values",
      "properties": {
        "veryHigh": {
          "type": "string"
        },
        "high": {
          "type": "string"
        },
        "medium": {
          "type": "string"
        },
        "low": {
          "type": "string"
        },
        "veryLow": {
          "type": "string"
        }
      }
    },
    "alertConditions": {
      "type": "array",
      "description": "Automated alert conditions",
      "items": {
        "type": "object",
        "required": ["severity", "condition"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"]
          },
          "condition": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Known limitations or caveats of this indicator"
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["fidleg", "euMiFID", "usSec", "ukFCA", "sgMAS"]
      },
      "description": "List of active regulatory extensions for this indicator"
    },
    "regulatoryExtensions": {
      "type": "object",
      "description": "Modular regulatory extensions for different jurisdictions"
    }
  }
}