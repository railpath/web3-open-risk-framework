{
  "name": "risk-catalogue-validator",
  "version": "1.0.0",
  "description": "Validator for Risk/Indicator/Assessment/Measure markdown files with YAML blocks against JSON Schema.",
  "type": "module",
  "main": "dist/risk-cli.js",
  "scripts": {
    "build": "tsc",
    "validate:schema": "npm run risk-cli -- validate schema",
    "validate:references": "npm run risk-cli -- validate references",
    "validate:all": "npm run risk-cli -- validate all",
    "template": "npm run build && node dist/template-cli.js",
    "risk-cli": "npm run build && node dist/risk-cli.js",
    "dev": "ts-node --esm src/validate-markdown.ts",
    "dev-references": "ts-node --esm src/validate-references.ts",
    "dev-template": "ts-node --esm src/template-cli.ts",
    "dev-risk-cli": "ts-node --esm src/risk-cli.ts"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
